# Testing and development purposes only
DEBUG=false

# Enables dry-run mode, which only simulates transactions without broadcasting them to the network
DRY_RUN=true

# SPRegistry database connection string used for admin operations
SP_REGISTRY_DATABASE_URL=

# Network RPC URL
RPC_URL=

# Private key used in client operations
CLIENT_PRIVATE_KEY=

# Private key used in admin operations
ADMIN_PRIVATE_KEY=

# Private key used in SP operations
SP_PRIVATE_KEY=

# Optional: organization address used by PoRepMarket to group providers.
# If unset, the script derives it from SP_PRIVATE_KEY.
SP_ORGANIZATION_ADDRESS=

# Optional: restrict SP automation to a single provider id (e.g. "f01234" or "1234").
SP_PROVIDER_ID=

# Optional: set true for cron automation to broadcast acceptDeal transactions.
# Safety default is false.
AUTO_ACCEPT=false


# Addresses of smart contract on the given network
POREP_MARKET=
CLIENT_CONTRACT=
SP_REGISTRY=
VALIDATOR_FACTORY=
FILECOIN_PAY=

# USDFC token used in PoRep Market system payments
# TODO LATER get this from smart contracts?
USDFC_TOKEN=
